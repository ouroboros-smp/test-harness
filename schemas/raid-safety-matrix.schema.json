{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ouroboros-smp/test-harness/schemas/raid-safety-matrix.schema.json",
  "title": "Ouroboros raid-safety acceptance matrix",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "title", "issue", "production", "foundations", "acceptance"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "title": { "type": "string", "minLength": 1 },
    "issue": {
      "type": "string",
      "pattern": "^https://github\\.com/ouroboros-smp/[A-Za-z0-9_.-]+/issues/[1-9][0-9]*$"
    },
    "production": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manifest", "portfolio", "requiredArtifacts"],
      "properties": {
        "manifest": { "$ref": "#/$defs/yamlPath" },
        "portfolio": { "$ref": "#/$defs/yamlPath" },
        "requiredArtifacts": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "foundations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "allOf": [
          { "$ref": "#/$defs/entry" },
          {
            "type": "object",
            "properties": {
              "status": { "const": "executable" },
              "scenarios": { "type": "array", "minItems": 1 }
            }
          }
        ]
      }
    },
    "acceptance": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/entry" }
    }
  },
  "$defs": {
    "yamlPath": {
      "type": "string",
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9_./-]+\\.ya?ml$"
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "status", "artifacts", "scenarios", "proves"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "title": { "type": "string", "minLength": 1 },
        "status": { "enum": ["executable", "blocked"] },
        "artifacts": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "scenarios": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "proves": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "limitations": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "blockers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["issue", "reason"],
            "properties": {
              "issue": {
                "type": "string",
                "pattern": "^https://github\\.com/ouroboros-smp/[A-Za-z0-9_.-]+/issues/[1-9][0-9]*$"
              },
              "reason": { "type": "string", "minLength": 1 }
            }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "type": "object",
            "properties": { "status": { "const": "executable" } }
          },
          "then": {
            "type": "object",
            "properties": { "scenarios": { "type": "array", "minItems": 1 } },
            "not": {
              "type": "object",
              "properties": { "blockers": true },
              "required": ["blockers"]
            }
          }
        },
        {
          "if": {
            "type": "object",
            "properties": { "status": { "const": "blocked" } }
          },
          "then": {
            "type": "object",
            "properties": {
              "scenarios": { "type": "array", "maxItems": 0 },
              "blockers": true
            },
            "required": ["blockers"]
          }
        }
      ]
    }
  }
}
